{
  "manifestVersion": 1,
  "id": "electrs",
  "name": "Electrs",
  "version": "0.10.0",
  "category": "bitcoin",
  "description": "High-performance Electrum server. Indexes the blockchain for wallets.",
  "icon": "🔍",
  "dependencies": ["bitcoind"],
  "inputs": [],
  "services": {
    "electrs": {
      "image": "mempool/electrs:latest",
      "entrypoint": "electrs",
      "command": "--network bitcoin --daemon-rpc-addr ${bitcoind.exports.rpc.host}:8332 --daemon-p2p-addr ${bitcoind.exports.rpc.host}:8333 --electrum-rpc-addr 0.0.0.0:50001 --db-dir /data --cookie ${bitcoind.exports.rpc.user}:${bitcoind.exports.rpc.password}",
      "ports": [{ "host": 50001, "container": 50001 }],
      "volumes": [{ "name": "electrs-data", "path": "/data" }],
      "healthcheck": { "type": "tcp", "port": 50001, "interval": "30s" }
    }
  },
  "probe": {
    "type": "electrum",
    "port": 50001,
    "display": [{ "label": "Height", "field": "height" }]
  },
  "exports": {
    "electrum.host": "electrs",
    "electrum.port": 50001
  }
}
