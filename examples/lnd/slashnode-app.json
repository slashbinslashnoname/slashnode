{
  "manifestVersion": 1,
  "id": "lnd",
  "name": "LND",
  "version": "0.18.0",
  "category": "lightning",
  "description": "Lightning Network implementation. Wires automatically to Bitcoin Core.",
  "icon": "⚡",
  "dependencies": ["bitcoind"],
  "inputs": [
    {
      "key": "ALIAS",
      "label": "Node alias",
      "type": "text",
      "required": true,
      "placeholder": "my-lightning-node"
    },
    {
      "key": "WALLET_PASSWORD",
      "label": "Wallet password",
      "type": "password",
      "required": true,
      "secret": true,
      "minLength": 12
    }
  ],
  "services": {
    "lnd": {
      "image": "lightninglabs/lnd:v0.18.0-beta",
      "ports": [
        { "host": 9735, "container": 9735 },
        { "hostIP": "127.0.0.1", "host": 8085, "container": 8080 }
      ],
      "volumes": [{ "name": "lnd-data", "path": "/data/.lnd" }],
      "healthcheck": { "type": "rpc", "method": "getinfo", "interval": "30s" }
    }
  },
  "wiring": {
    "bitcoind.rpchost": "${bitcoind.exports.rpc.host}",
    "bitcoind.rpcuser": "${bitcoind.exports.rpc.user}",
    "bitcoind.rpcpass": "${bitcoind.exports.rpc.password}",
    "bitcoind.zmqpubrawblock": "${bitcoind.exports.zmq.rawblock}"
  },
  "probe": {
    "type": "lnd",
    "port": 8085,
    "display": [
      { "label": "Height", "field": "block_height" },
      { "label": "Synced", "field": "synced_to_chain" }
    ]
  }
}
