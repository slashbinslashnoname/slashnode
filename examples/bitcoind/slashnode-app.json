{
  "manifestVersion": 1,
  "id": "bitcoind",
  "name": "Bitcoin Core",
  "version": "27.0",
  "category": "bitcoin",
  "description": "The reference Bitcoin node. Validates the blockchain and exposes the RPC API.",
  "icon": "₿",
  "dependencies": [],
  "inputs": [
    {
      "key": "RPC_USER",
      "label": "RPC user",
      "type": "text",
      "required": true,
      "default": "slashnode",
      "help": "Username for the bitcoind RPC API."
    },
    {
      "key": "RPC_PASSWORD",
      "label": "RPC password",
      "type": "password",
      "required": true,
      "secret": true,
      "minLength": 12,
      "help": "Password for the RPC API. Stored encrypted."
    },
    {
      "key": "NETWORK",
      "label": "Network",
      "type": "select",
      "options": ["mainnet", "testnet", "signet"],
      "default": "mainnet"
    },
    {
      "key": "PRUNE_GB",
      "label": "Prune (GB, 0 = full node)",
      "type": "number",
      "default": 0,
      "min": 0
    }
  ],
  "services": {
    "bitcoind": {
      "image": "lncm/bitcoind:v27.0",
      "ports": [
        { "host": 8333, "container": 8333 },
        { "hostIP": "127.0.0.1", "host": 8332, "container": 8332 }
      ],
      "volumes": [{ "name": "bitcoin-data", "path": "/data/.bitcoin" }],
      "healthcheck": { "type": "rpc", "method": "getblockchaininfo", "interval": "30s" }
    }
  },
  "configs": [
    {
      "path": "/data/.bitcoin/bitcoin.conf",
      "content": "server=1\ntxindex=1\nrpcuser=${input.RPC_USER}\nrpcpassword=${secret.RPC_PASSWORD}\nrpcbind=0.0.0.0\nrpcallowip=0.0.0.0/0\nzmqpubrawblock=tcp://0.0.0.0:28332\nzmqpubrawtx=tcp://0.0.0.0:28333\n"
    }
  ],
  "probe": {
    "type": "rpc",
    "port": 8332,
    "method": "getblockchaininfo",
    "userInput": "RPC_USER",
    "passSecret": "RPC_PASSWORD",
    "display": [
      { "label": "Height", "field": "blocks" },
      { "label": "Headers", "field": "headers" }
    ]
  },
  "exports": {
    "rpc.host": "bitcoind",
    "rpc.port": 8332,
    "rpc.user": "${input.RPC_USER}",
    "rpc.password": "${secret.RPC_PASSWORD}",
    "zmq.rawblock": "tcp://bitcoind:28332"
  }
}
