{
  "manifestVersion": 1,
  "id": "lnd",
  "name": "LND",
  "version": "0.18.0",
  "category": "lightning",
  "description": "Lightning Network implementation. Wires automatically to Bitcoin Core.",
  "icon": "⚡",
  "dependencies": ["bitcoind"],
  "inputs": [
    {
      "key": "ALIAS",
      "label": "Node alias",
      "type": "text",
      "required": true,
      "placeholder": "my-lightning-node"
    },
    {
      "key": "WALLET_PASSWORD",
      "label": "Wallet password",
      "type": "password",
      "required": true,
      "secret": true,
      "minLength": 12
    }
  ],
  "services": {
    "lnd": {
      "image": "lightninglabs/lnd:v0.18.0-beta",
      "ports": [
        { "host": 9735, "container": 9735 },
        { "hostIP": "127.0.0.1", "host": 8085, "container": 8080 }
      ],
      "volumes": [{ "name": "lnd-data", "path": "/root/.lnd" }],
      "healthcheck": { "type": "rpc", "method": "getinfo", "interval": "30s" }
    }
  },
  "configs": [
    {
      "path": "/root/.lnd/lnd.conf",
      "content": "[Application Options]\nalias=${input.ALIAS}\nrestlisten=0.0.0.0:8080\n\n[Bitcoin]\nbitcoin.active=true\nbitcoin.mainnet=true\nbitcoin.node=bitcoind\n\n[Bitcoind]\nbitcoind.rpchost=${bitcoind.exports.rpc.host}:8332\nbitcoind.rpcuser=${bitcoind.exports.rpc.user}\nbitcoind.rpcpass=${bitcoind.exports.rpc.password}\nbitcoind.zmqpubrawblock=${bitcoind.exports.zmq.rawblock}\nbitcoind.zmqpubrawtx=tcp://bitcoind:28333\n"
    }
  ],
  "probe": {
    "type": "lnd",
    "port": 8085,
    "display": [
      { "label": "Height", "field": "block_height" },
      { "label": "Synced", "field": "synced_to_chain" }
    ]
  },
  "endpoints": [
    { "label": "REST API", "scheme": "https", "port": 8085, "path": "/v1/getinfo" },
    { "label": "P2P", "port": 9735 }
  ]
}
