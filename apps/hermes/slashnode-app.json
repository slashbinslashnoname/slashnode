{
  "manifestVersion": 1,
  "id": "hermes",
  "name": "Hermes Agent",
  "version": "latest",
  "category": "ai",
  "description": "Nous Research Hermes — autonomous AI agent with a web dashboard.",
  "icon": "🪽",
  "dependencies": [],
  "inputs": [
    {
      "key": "HERMES_DASHBOARD_BASIC_AUTH_USERNAME",
      "label": "Dashboard username",
      "type": "text",
      "required": true,
      "default": "admin"
    },
    {
      "key": "HERMES_DASHBOARD_BASIC_AUTH_PASSWORD",
      "label": "Dashboard password",
      "type": "password",
      "required": true,
      "secret": true,
      "minLength": 8
    }
  ],
  "services": {
    "hermes": {
      "image": "nousresearch/hermes-agent:latest",
      "command": "gateway run",
      "shmSize": "1g",
      "ports": [{ "host": 9119, "container": 9119 }],
      "volumes": [{ "name": "hermes-data", "path": "/opt/data" }],
      "environment": {
        "HERMES_DASHBOARD": "1",
        "HERMES_DASHBOARD_HOST": "0.0.0.0",
        "HERMES_DASHBOARD_PORT": "9119"
      },
      "healthcheck": { "type": "http", "path": "/", "port": 9119, "interval": "30s" }
    }
  },
  "exports": {
    "dashboard.host": "hermes",
    "dashboard.port": 9119
  },
  "web": { "port": 9119, "path": "/" },
  "probe": { "type": "http", "port": 9119, "path": "/" },
  "notes": "Configure Hermes from its console: open the console and run `hermes-agent setup` to add your model provider keys (Anthropic / OpenAI) and platforms. The dashboard login uses the username/password set above."
}
